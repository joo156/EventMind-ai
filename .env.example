# EventMind AI - Environment Configuration
# Copy this file to .env.local and fill in your own values

# ================================================================================
# AI PROVIDER CONFIGURATION
# ================================================================================
# Select which AI provider to use for event extraction and editing
# Options: gemini (default), openai, anthropic, openrouter
VITE_AI_PROVIDER=gemini

# API key for your selected AI provider
# - Google Gemini: Get from https://ai.google.dev/
# - OpenAI: Get from https://platform.openai.com/account/api-keys
# - Anthropic: Get from https://console.anthropic.com/
# - OpenRouter: Get from https://openrouter.ai/keys
VITE_AI_API_KEY=your_api_key_here

# Optional: Specify a custom model for your AI provider
# If not set, will use provider defaults:
#   - Gemini: gemini-2.0-flash
#   - OpenAI: gpt-4-turbo
#   - Anthropic: claude-3-sonnet-20240229
#   - OpenRouter: google/gemini-2.0-flash-exp
# VITE_AI_MODEL=gemini-2.0-flash

# ================================================================================
# SUPABASE CONFIGURATION
# ================================================================================
# Get these values from your Supabase project settings
# https://app.supabase.com/projects

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase public API key (anon key)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ================================================================================
# DEPLOYMENT & DEVELOPMENT
# ================================================================================
# Current deployment environment
# NODE_ENV=development

# Vercel deployment URL (set automatically by Vercel)
# VERCEL_URL=https://your-domain.vercel.app

# ================================================================================
# NOTES
# ================================================================================
# 1. VITE_* variables are exposed to the client (keep API keys secret!)
# 2. Store sensitive values in .env.local (never commit to git)
# 3. For local development, create .env.local with your API keys
# 4. For production, set environment variables in your deployment platform
# 5. Server-side environment variables (like VITE_AI_API_KEY) are NOT exposed to the client
